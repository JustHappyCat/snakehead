DATABASE_URL="postgresql://postgres:postgres@postgres:5432/seo_spider"
REDIS_HOST="redis"
REDIS_PORT="6379"
NODE_ENV="development"
AUTH_TOKEN="change-me-to-a-secure-password"

# AI Recommendations
OPENAI_API_KEY=your_api_key_here
OPENAI_MODEL=gpt-3.5-turbo
AI_RECOMMENDATIONS_ENABLED=true
AI_RECOMMENDATIONS_CACHE_TTL=86400
AI_RECOMMENDATIONS_MAX_DAILY_COST=10.00
AI_RECOMMENDATIONS_MAX_COST_PER_USER=1.00
AI_RECOMMENDATIONS_RATE_LIMIT_RPM=60
AI_RECOMMENDATIONS_RATE_LIMIT_TPM=150000
AI_RECOMMENDATIONS_CACHE_PREFIX=ai-rec:
