{
  "compilerOptions": {
    "lib": ["ES2020"],
    "module": "commonjs",
    "target": "es2020",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "forceConsistentCasingInFileNames": true
  },
  "include": ["index.ts", "types.ts", "constants.ts", "url.ts", "crawl-settings.ts"]
}
